# Clerk dashboard keys: Part 1 at 00:42:56. Paste keys at 00:45:04.
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=

# Clerk webhook signing secret: Part 1 at 01:40:31. Copy the secret at 01:41:45.
CLERK_WEBHOOK_SECRET=

# Clerk redirect settings: Part 1 at 00:53:02.
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
NEXT_PUBLIC_CLERK_SIGN_IN_FALLBACK_REDIRECT_URL=/
NEXT_PUBLIC_CLERK_SIGN_UP_FALLBACK_REDIRECT_URL=/

# Database URL: Part 1 at 01:11:22. Paste the provider URL at 01:13:20.
# Local development works with SQLite. Replace this when you configure a hosted database.
DATABASE_URL=file:./dev.db

# LiveKit project keys: Part 2 at 00:23:41. Paste them at 00:24:12.
LIVEKIT_API_URL=
LIVEKIT_API_KEY=
LIVEKIT_API_SECRET=

# LiveKit WebSocket URL: Part 2 at 00:25:02.
NEXT_PUBLIC_LIVEKIT_WS_URL=

# UploadThing setup: Part 2 at 04:11:50. The tutorial copies keys at 04:12:26.
# The current UploadThing SDK uses one token. The older video uses UPLOADTHING_SECRET
# and UPLOADTHING_APP_ID instead.
UPLOADTHING_TOKEN=
